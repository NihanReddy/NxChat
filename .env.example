# Database Configuration
DB_URL=jdbc:mysql://localhost:3306/chatflow?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true&createDatabaseIfNotExist=true
DB_USERNAME=root
DB_PASSWORD=your_database_password_here

# Redis Configuration (Optional)
# REDIS_HOST=your_redis_host.ec2.cloud.redislabs.com
# REDIS_PORT=15925
# REDIS_USER=default
# REDIS_PASSWORD=your_redis_password_here
# REDIS_SSL=false
# REDIS_URL=redis://default:your_redis_password_here@your_redis_host.ec2.cloud.redislabs.com:15925

# Mail Configuration (Optional if OTP is disabled)
# MAIL_HOST=smtp-relay.brevo.com
# MAIL_PORT=587
# MAIL_USERNAME=your_email@smtp-brevo.com
# MAIL_PASSWORD=your_mail_password_here
# MAIL_SMTP_AUTH=true
# MAIL_SMTP_STARTTLS_ENABLE=true

# Google OAuth2 Configuration
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Security
JWT_SECRET=your_jwt_secret_key_here
